{
    // =========================
    // CONFIGURAÇÕES DE TEMA
    // =========================
    "workbench.colorTheme": "Tokyo Night",
    "workbench.iconTheme": "helium-icon-theme",
    "workbench.productIconTheme": "bongocat",
    "window.zoomLevel": 0,

    // =========================
    // CONFIGURAÇÕES DE EDITOR
    // =========================
    "editor.fontSize": 18,
    "editor.fontFamily": "JetBrains Mono, 'Courier New'",
    "editor.fontLigatures": true,
    "editor.lineHeight": 1.6,
    "editor.formatOnSave": true,
    "editor.formatOnPaste": true,
    "editor.minimap.enabled": true,
    "editor.minimap.scale": 1,
    "editor.roundedSelection": true,
    "editor.bracketPairColorization.enabled": true,
    "editor.guides.bracketPairs": "active",
    "editor.scrollBeyondLastLine": false,
    "editor.inlineSuggest.enabled": false,
    "editor.suggesting": true,
    "editor.suggestFontSize": 13,
    "editor.wordWrap": "on",
    "editor.trimAutoWhitespace": true,
    "editor.accessibilitySupport": "off",

    // =========================
    // CONFIGURAÇÕES DA ÁREA DE TRABALHO
    // =========================
    "workbench.startupEditor": "none",
    "workbench.editor.closeOnFileDelete": true,
    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "explorer.compactFolders": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": true,

    // =========================
    // CONFIGURAÇÕES DE ARQUIVOS
    // =========================
    "files.autoSave": "afterDelay",
    "files.autoSaveDelay": 1000,
    "files.trimTrailingWhitespace": true,
    "files.trimFinalNewlines": true,
    "files.insertFinalNewline": true,
    "files.associations": {
        "*.cu": "cpp",
        "*.cuh": "cpp"
    },

    // =========================
    // CONFIGURAÇÕES DO TERMINAL
    // =========================
    "terminal.integrated.fontSize": 13,
    "terminal.integrated.fontFamily": "JetBrains Mono",
    "terminal.integrated.lineHeight": 1.5,
    "terminal.integrated.smoothScrolling": true,
    "terminal.integrated.copyOnSelection": true,
    "terminal.integrated.enablePersistentSessions": true,

    // =========================
    // CODE RUNNER
    // =========================
    "code-runner.executorMap": {
        "python": "clear ; python -u",
        "javascript": "node",
        "cpp": "g++ -o $dir\\$fileNameWithoutExt.exe $file && $dir\\$fileNameWithoutExt.exe"
    },
    "code-runner.runInTerminal": true,
    "code-runner.ignoreSelection": true,
    "code-runner.showRunningInTerminal": true,

    // =========================
    // C++ / C CONFIGURATION
    // =========================
    "[cpp]": {
        "editor.inlineSuggest.enabled": false,
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools"
    },
    "C_Cpp.clang_format_style": "file",
    "C_Cpp.codeAnalysis.enabled": true,
    "C_Cpp.codeAnalysis.runSecondaryCodeAnalysis": true,
    "C_Cpp.intelliSenseEngine": "default",
    "C_Cpp.intelliSenseEngineFallback": "enabled",

    // =========================
    // PYTHON CONFIGURATION
    // =========================
    "[python]": {
        "editor.defaultFormatter": "ms-python.python",
        "editor.formatOnSave": true,
        "editor.rulers": [79, 120]
    },
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": true,
    "python.formatting.provider": "black",

    // =========================
    // SQL CONFIGURATION
    // =========================
    "[sql]": {
        "editor.defaultFormatter": "dorzey.vscode-sqlformat",
        "editor.formatOnSave": true
    },

    // =========================
    // JSON CONFIGURATION
    // =========================
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.formatOnSave": true
    },
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },

    // =========================
    // CONFIGURAÇÕES DE SEARCH
    // =========================
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/.git": true,
        "**/CMakeFiles": true
    },
    "files.exclude": {
        "**/node_modules": true,
        "**/.git": true,
        "**/CMakeLists.txt": false
    },

    // =========================
    // GITHUB COPILOT
    // =========================
    "github.copilot.enable": false,

    // =========================
    // EXTENSÕES E PLUGINS
    // =========================
    "peacock.affectTab": true,
    "peacock.affectActivityBar": true,

    // =========================
    // PERFORMANCE
    // =========================
    "extensions.autoUpdate": true,
    "update.mode": "start",
    "telemetry.telemetryLevel": "off"
}